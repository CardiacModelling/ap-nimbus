  "pacingFrequency": 0.5
}
END

# Simulation request (pipe to jq is optional) : Record the simulation 'id'

curl --header "Expect: " --header "Content-Type:application/json" -X POST -d @request.json http://<host>:8080/ | jq

# Simulation results/progress response (pipe to jq is optional) : Output data (note content type of "text/plain"... albeit json format text)

curl -H "Content-Type: text/plain; charset=utf-8" -X GET http://<host>:8080/api/collection/<sim id>/progress_status | jq
curl -H "Content-Type: text/plain; charset=utf-8" -X GET http://<host>:8080/api/collection/<sim id>/STOP | jq
curl -H "Content-Type: text/plain; charset=utf-8" -X GET http://<host>:8080/api/collection/<sim id>/voltage_traces | jq
curl -H "Content-Type: text/plain; charset=utf-8" -X GET http://<host>:8080/api/collection/<sim id>/voltage_results | jq
