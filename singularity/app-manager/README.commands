      },
      {
        "pIC50": 4.3,
        "hill": 0.92,
        "saturation": 0
      },
      {
        "pIC50": 4.3,
        "hill": 0.92,
        "saturation": 0
      },
      {
        "pIC50": 4.3,
        "hill": 0.92,
        "saturation": 0
      }
    ],
    "spreads": {
      "c50Spread": null,
      "hillSpread": null
    }
  },
  "ICaL": {
