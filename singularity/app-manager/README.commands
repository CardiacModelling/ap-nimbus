# Create persistent overlay

touch my_overlay
dd if=/dev/zero of=my_overlay bs=1M count=10 && mkfs.ext3 my_overlay

# Run the singularity container (using above overlay)

singularity run --overlay my_overlay app-manager.img

# Prepare simulation request.

cat > request.json << END
{
  "metaData": {
    "title": "Quattro,FLIPR,Barracuda@0.5Hz",
    "groupLevel": 1,
    "pacingFrequency": 0.5
  },
  "created": 1562590446666,
  "modelId": 1,
  "pacingMaxTime": 5,
  "plasmaPoints": [
    0,
    0.3,
